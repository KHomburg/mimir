{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mimir",
  "version": "0.1.0",
  "identifier": "io.mimir.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "mimir",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:mimir.db"]
    },
    "deep-link": {
      "desktop": {
        "schemes": ["mimir", "io.mimir.app"]
      },
      "mobile": [
        {
          "scheme": ["mimir", "io.mimir.app"],
          "appLink": false
        }
      ]
    }
  }
}
